# ============================================================
# Конфигурация окружения — Inventory Bot
# Скопируйте этот файл в .env и заполните реальные значения
# ============================================================

# Секретный ключ Flask (ОБЯЗАТЕЛЕН)
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-with-python

# Режим запуска
# DEBUG=false для продакшн, DEBUG=true только при разработке
DEBUG=false
FLASK_ENV=production

# Порт запуска
PORT=5000

# Путь к базе данных (относительно корня проекта)
DATABASE_URL=data/assets.db

# HTTPS (установите true если за nginx/reverse-proxy с SSL)
HTTPS_ENABLED=false

# Пароль администратора по умолчанию (оставьте пустым чтобы использовать встроенный)
DEFAULT_ADMIN_PASSWORD=

# Часовой пояс планировщика
SCHEDULER_TIMEZONE=Asia/Tomsk

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
